generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  body        String
  category    String
  priority    String
  publishDate DateTime
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
